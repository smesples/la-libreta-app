{
  "name": "Transaccion",
  "type": "object",
  "properties": {
    "tipo": {
      "type": "string",
      "enum": ["ingreso", "gasto"],
      "description": "Tipo de transacción"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "venta", "servicio", "otro_ingreso", "materia_prima", "empaque", 
        "mercaderia", "envios", "servicios_negocio", "alquiler_negocio", 
        "salarios", "publicidad", "otros_gastos_negocio", "alimentacion", 
        "servicios_hogar", "alquiler_hogar", "salud", "educacion", "otros_gastos_hogar"
      ],
      "description": "Categoría de la transacción"
    },
    "monto": {
      "type": "number",
      "description": "Monto de la transacción"
    },
    "descripcion": {
      "type": "string",
      "description": "Descripción opcional"
    },
    "fecha": {
      "type": "string",
      "format": "date",
      "description": "Fecha de la transacción"
    },
    "es_costo_fijo": {
      "type": "boolean",
      "default": false,
      "description": "Si es un costo fijo mensual"
    },
    "modalidad_pago": {
      "type": "string",
      "enum": ["contado", "a_cuenta"],
      "description": "Modalidad de pago para ingresos"
    },
    "es_gasto_negocio": {
      "type": "boolean",
      "default": true,
      "description": "Si el gasto pertenece al negocio (true) o al hogar (false)"
    },
    "usuarioId": { 
      "type": "string", 
      "description": "ID único del productor para la prueba piloto" 
    }
  },
  "required": [
    "tipo",
    "categoria",
    "monto",
    "fecha",
    "usuarioId"
  ]
}
